{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/recertification_dashboard.html" }
  ],
  "functions": {
    "api/refresh.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
